[SP-Hotel]
PrimarySpawnPoint=Szyb windy
SecondarySpawnPoint=Klatka schodowa
CampaignObjectiveHostageSpawn=("Lawrence Adams","James Bettincourt")
MissionDescription=("Odbicie zakladnikow","1700 West 7th Ave.","1 maja, godz. 18:12")
BriefingText=("Panowie, sytuacja juz wymknela sie spod kontroli, a wszystko wskazuje na to, ze bedzie jeszcze gorzej. Paramilitarna grupa 'Teraz Ameryka' wziela dwoch zakladnikow: Jamesa Bettincourta juniora, dziedzica firmy budowlanej, i Lawrence'a Adamsa, jego glownego kontrahenta. Obaj zostali pojmani podczas inspekcji prac prowadzonych przez pracownikow Adamsa w hotelu 'Old Granite'. W chwili obecnej podejrzani ukrywaja sie na dwoch najwyzszych pietrach hotelu i zad a dostarczenia 12 milionow dolarow okupu jeszcze dzis do polnocy. Twierdza, ze firma Bettincourta jest im winna te kwote, poniewaz posiada dlug w stosunku do obywateli Stanow Zjednoczonych.'","|'Teraz Ameryka' to mala, lecz przezna paramilitarna grupa promujaca idee skrajnego izolacjonizmu. Sprzeciwia sie imigracji, wolnemu handlowi oraz przedsiebiorstwom z udzialem zagranicznego kapitalu. Wiekszosc ich akcji wymierzona byla w te ostatnie, przybierajac forme sabotazu lub daleko posunietego wandalizmu. To porwanie jest ich pierwsza akcja tego typu, co moze sugerowac zmiane taktyki. Zwa zywszy na pozycje porwanych, podejrzani najprawdopodobniej licza na rozglos. Media wyrazily chec wspolpracy, ale nie wiemy, jak dlugo mozemy na nich polegac.","|Oczekujcie, ze podejrzani beda dobrze uzbrojeni i potrafia dzialac w grupie, ale brak doswiadczenia w porwaniach moze uczynic te sytuacje jeszcze bardziej niebezpieczna dla cywili. Uwazajcie na wszystko.","|Teraz kilka slow o porwanych. James Bettincourt junior jest synem wlasciciela i prezesa zarzadu Bettincourt Investments, francuskiej spolki budowlanej. Sze sc miesiecy temu, po ogloszeniu bankructwa przez wlasciciela wspomnianego hotelu, firma wykupila budynek i prowadzi w nim prace remontowe. Syn wlasciciela pelni role glownego nadzorcy prac. Lawrence Adams to glowny architekt i szef firmy dokonujacej remontu. Obaj zostali porwani podczas inspekcji robot.","|Podejrzani przebywaja na VI i VII pietrze. Mozecie wejsc schodami albo tez przez dach i dalej szybem windy. Niedawno z VII pietra dobiegly strzaly, wiec nie mozemy czekac ani chwili dluzej. ")
LocationInfoText=("Hotel Old Granite, 1700 West 7th Ave.","|","Sierra Jeden ma pod kontrola odslonieta czesc budynku (strona 1, poziom 7).")
HostageName=("James Bettincourt jr","Lawrence Adams")
HostageVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Brazowe|Oczy: Brazowe|Wzrost: 183 cm|Waga: 72 kg|Data ur.: 01/04/75|Wiek: 33","Plec: Mezczyzna|Rasa: Biala|Wlosy: Czarne|Oczy: Niebieskie|Wzrost: 178 cm|Waga: 85 kg|Data ur.: 04/19/66|Wiek: 42")
HostageDescription=("Syn Jamesa Bettincourta, prezesa zarzadu firmy Bettincourt Investments, wlasciciela hotelu Old Granite.","Lawrence Adams jest glownym wykonawca prac remontowych w hotelu.")
SuspectName=("Nieznany")
SuspectVitals=("")
SuspectDescription=("Posiadaja kamizelki kuloodporne i maski oraz bron automatyczna.")
EntryOptionTitle=("Szyb windy","Klatka schodowa")
EntryDescription=("Wejscie z dachu windy zatrzymanej na 5 pietrze.","Wejscie z klatki schodowej na 5 pietrze.")
TimeLinePlot=(0,31,38,42,48,58,96,100)
TimeLineTime=("12:30","14:17","14:40","14:53","15:12","15:47","17:57","18:12")
TimeLineShortDescription=("Spotkanie","Utrata kontaktu","Zadanie okupu","Przybycie SWAT","Dodatkowe zadania","Dodatkowe zadania","Fiasko negocjacji","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Arranged meeting: Bettincourt and Adams meet at the hotel construction site."," - Kevin Halskey, Bettincourt's chauffeur, attempts to contact Bettincourt via cellphone and fails."," - Charles Bettincourt, owner and CEO of Bettincourt Investments, contacted with a demand for 12 million dollars by midnight.  Failure to comply will result in the death of the hostages. Dispatch notified; emergency services notified.  SWAT responds."," - SWAT arrives. Containment perimeter and high ground put in place."," - CNT makes contact with the suspects.  Demand for 12 milllion dollars repeated, along with midnight deadline.  Additional 10 million dollars to be added to ransom for every hour after 21:00 it is late. CNT continues negotiations."," - Suspects make another demand, that their ''New American Manifesto'' be published in a national newspaper. CNT requests release of a hostage in exchange; suspects refuse."," - CNT reports that suspects appear to still be confident of getting their demands met.  CNT says that no further progress can be expected through negotiations."," - Decision made to go tactical. Entry team assembled.")
LoadingText=1700 West 7th Ave., hotel Old Granite

[SP-DNA]
PrimarySpawnPoint=Drzwi frontowe
SecondarySpawnPoint=Wejscie zapasowe
CampaignObjectiveEnemySpawn=("Jean Trouffant")
CampaignObjectiveHostageSpawn=("Dr Theodore Sterling")
MissionDescription=("Szturm / Odbicie zakladnikow","72 Mt. Threshold Avenue","21 maja, godz. 00:45")
BriefingText=("Jesli nie slyszeliscie jeszcze o Armii Wiary, to macie wlasnie okazje. Krotko po godzinie 20:00 kilku jej czlonkow wdarlo sie do centrum badawczego Hologen w Mount Threshold, powiaz anego z Uniwersytetem Mount Threshold. Paru radiowozow odpowiedzialo na wezwanie i w obecnej chwili osrodek jest otoczony przez policje. Niestety, razem z czlonkami organizacji w budynku przebywaja pracownicy i studenci, zas napastnicy oglosili, ze sa gotowi umrzec za swoja sprawe i wszystko wskazuje na to, ze moga tez uczynic meczennikow z innych. Sytuacja jest bardzo delikatna, w kazdej chwili moze dojsc do masakry.","|Kilka slow o 'Armii Wiary'. Po raz pierwszy pojawili sie okolo 2 lat temu. Od tej pory dokonali kilku zamachow bombowych na osrodki badawcze pracujace nad klonowaniem organizmow. Nie traktujcie ich jednak jak wariatow - sa dobrze uzbrojeni, swietnie wyszkoleni i fanatycznie oddani swojej sprawie. Wydali kilka wyrokow smierci na czolowych naukowcow zajmujacych sie klonowaniem, a czesc z nich wykonali. ","|Przypuszczam, ze chcieli dokonac szybkiego, niszczycielskiego ataku na siedzibe Hologenu, ale zostali zaskoczeni przez ochrone uniwersytetu. Wciaz panuje tam spore zamieszanie, wiec nie jestesmy w stanie ocen ic, ile osob postronnych znajduje sie wewnatrz ani jak z duza liczba napastnikow mamy do czynienia. ","|Hologen prowadzi badania nad klonowaniem DNA i pewnie dlatego stal sie celem ataku. Wiemy, ze grupa dowodzi jeden z 'oficerow' Armii Wiary, niejaki Jean Trouffant, poszukiwany za ataki bombowe na kliniki przeprowadzajace zabiegi przerywania ciazy. Z zeznan naocznych swiadkow mozna wniesc, ze towarzyszy mu siedmiu lub osem ludzi.","|Atak rozpoczal sie od unieszkodliwienia systemu monitorujacego, wiec nie wiemy, ilu cywilow znajduje sie w srodku. Jak na razie, napastnicy zawiadomili, ze wzieli doktora Theodore'a Sturgeona jako zakladnika. Podejrzewamy, ze grozi mu smierc. Jak zwykle, naszym glownym celem jest ewakuacja wszystkich cywilow. Musicie jednak zwrocic dodatkowa uwage na teczke Sturgeona, w ktorej znajduja sie dane wielu naukowcow z calego swiata. W rekach Armii Wiary moga stac sie one lista przyszlych ofiar zamachow. Przyjrzyjcie sie planom, wybierzcie odpowiedni sprzet i ruszamy. Mamy malo czasu. ")
LocationInfoText=("72 Mount Threshold Ave.  Budynek ma duzy hol i sporo pomieszczen laboratoryjnych polaczonych w dosc zlozony sposob.","Snajperzy nie moga oslania teren poza samym holem.")
HostageName=("Theodore Sturgeon")
HostageVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Siwe|Oczy: Brazowe|Wzrost: 178 cm|Waga: 86 kg|Data ur.: 9/23/48|Wiek: 60")
HostageDescription=("Profesor biochemii na uniwersytecie Mount Threshold. Zbieznosc nazwisk ze znanym pisarzem s-f jest zupelnie przypadkowa.")
SuspectName=("Jean Trouffant","Nieznani wspolnicy")
SuspectVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Kasztanowate|Oczy: Niebieskie|Wzrost: 5, 11|Waga: 175|Data ur.: 19/04/73|Wiek: 35","Cechy: Nieznane")
SuspectDescription=("Pochodzacy z Francji Trouffant jest gleboko oddany sprawie Armii Wiary. Kilkakrotnie aresztowany za nieobyczajne zachowanie i zaklocanie porzadku publicznego.","Zamaskowani napastnicy")
EntryOptionTitle=("Strona 1, Poziom 1","Strona 2, Poziom 2")
EntryDescription=("Wejscie od strony glownych drzwi i foyer.","Wejscie zapasowe.")
TimeLinePlot=(0,3,6,60,76,92,100)
TimeLineTime=("20:12","20:19","20:28","22:43","23:27","00:12","00:45")
TimeLineShortDescription=("Alarm odciety","Przybycie policji","Przybycie SWAT","Rozpoczecie negocjacji ","Negocjatorzy identyfikuj a Trouffanta","Podejrzani stawiaja zadania","Zatwierdzenie szturmu")
TimeLineLongDescription=(" - Uniwersytecka policja traci lacznosc z systemem bezpieczenstwa. Na miejsce zostaje wyslany patrol."," - Funkcjonariusze przybywaja na miejsce i znajduja przeciete kable. Chwile pozniej zostaja ostrzelani z wnetrza budynku. Do centrali zostaje skierowane powiadomienie i prosba o wyslanie grupy szturmowej."," - Zabezpieczenie terenu i zajecie pozycji przez snajperow.","-  Negocjatorzy kontaktuja sie z porywaczami i rozpoznaja wsrod nich Jeana Trouffanta."," - Podczas rozmowy odczytany zostaje manifest Armii Wiary, co potwierdza podejrzenia."," - Porywacze stawiaja dodatkowe zadania dotyczace dostarczenia zywnosci i amunicji. Negocjatorzy zgadzaja sie wylacznie na zywnosc. Porywacze wykazuja niezadowolenie i groza zakladnikom."," - Kolejne proby kontaktu z Trouffantem koncza sie niepowodzeniem. Negocjatorzy obawiaja sie, ze moze to oznaczac zagrozenie zycia zakladnikow i sugeruja rozpoczecie szturmu.")
LoadingText=72 Mt. Threshold Ave, Centrum Badawcze Mt. Threshold

