CampaignObjectiveEnemySpawn=("Andrew Taronne")
MissionDescription=("Dzialanie podwyzszonego ryzyka","2189 Carrols Road","2 kwietnia, godz. 16:45")
BriefingText=("Panowie, sprawa jest powazna. Niecal a godzine temu otrzymalismy anonimowy telefon, ze czlonkowie sekty znanej jako Dzieci Taronne'a zamierzaja wysadzic w powietrze swoja siedzibe, co moze stanowic powazne zagrozenie dla wszystkich znajdujacych sie w poblizu budynkow.","|Oficerowie sledczy sprawdzili slady prowadzace do sekty i ustalili, ze w ostatnich dniach jej czlonkowie zakupili spora ilosc roznych chemikaliow oraz ogromne ilosci nawozow sztucznych. Musimy traktowac ostrzezenie bardzo powaznie. Nasz rozmowca nie podal czasu ani daty i rozlaczyl sie, nim zdozalismy zdobyc jakies dodatkowe informacje. Sadzimy, ze byl to jeden z eks - czlonkow sekty i aktualnie sprawdzamy, czy ktorys z nich nie wrocil do domu, ale nie uzyskalismy jeszcze zadnych danych. Nie mozemy jednak dluzej czekac. Detektywi otoczyli teren i nawo luja podejrzanych do wyjscia, jak na razie bezskutecznie.","| Jesli chodzi o Dzieci Taronne'a to jest to odlam separatystycznej grupy z Idaho. Ich liderem jest Andre Tarronne, ktorego uwazaja za guru i proroka. Pojawili sie tutaj jakies 3 lata temu i wykupili stary apartamentowiec i od razu sie do niego wprowadzili. Wychodza w grupach co najmniej 3 - osobowych i nie pozwalaja wejsc nikomu obcemu. ","| Wszystko co robia, robia z rozkazu Tarrone'a, wiec to z nim powinnismy pogadac. Jednakze Tarrone nigdy nie opuszcza domu, wiec to my musimy zlozyc mu wizyte. Grupa mocno wierzy w samoobrone i zapewne bedzie stawiala zaciekly opor. Oczekujcie uzbrojonej linii obrony i nie badzcie zaskoczeni jesli nawet nieuzbrojony kultysta bedzie stawial zaciekly opor przed poddaniem sie. Miejcie oczy szeroko otwarte na dzieci czlonkow kultu.","| Budynek ten byl standardowym apartamentowcem zanim Dzieci Taronne'a sie wprowadzily, jednak mogli go oni zmienic. Plany poszczegolnych pietr beda stanowic wzor, jednak mozecie oczekiwac niespodzianek. Zal ozcie, ze z materialami wybuchowymi obchodzono sie nierozwaznie. Zabladana kula moze spowodowac niechciane ofiary, wiec dobrze sie zastanowcie nad wyborem uzbrojenia.")
LocationInfoText=("2189 Carrols Road","|Jak na razie nikt nie przedostal sie do budynku. Z dokumentow wynika, ze sekta jest wlascicielem posesji od przeszlo 10 lat. Obserwacja zewnetrzna pozwala stwierdzic, ze wewnatrz budynku dokonano istotnych zmian, choc wlasciciele nigdy nie prosili o pozwolenie przebudowe.|Sierra Jeden kryje strone 2, poziom 2 z dachu pobliskiego budynku, Sierra Dwa kryje strone 1, poziom 2.")
HostageName=("Nieznany")
HostageVitals=("Cechy: Nieznane")
HostageDescription=("Informacja niedostepna")
SuspectName=("Andrew Taronne")
SuspectVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Czarne, siwiejace|Oczy: Brazowe|Wzrost: 180 cm|Waga: 105 kg|Data ur.: 12/03/59|Wiek: 49")
SuspectDescription=("Przywodca Dzieci Taronne'a. Charyzmatyczny i nieobliczalny przywodca, ktory dzieki indoktrynacji potrafil przywiazac do siebie grupe slepo oddanych fanatykow.")
EntryOptionTitle=("Strona 1, Poziom 1","Strona 2, Poziom 2")
EntryDescription=("Glowne drzwi","Wyjscie ewakuacyjne")
TimeLinePlot=(0,6,10,100)
TimeLineTime=("11:30","11:49","12:00","16:45")
TimeLineShortDescription=("Otrzymanie nakazu","Przybycie SWAT","Wywolanie","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Wydany zostaje nakaz aresztowania Andrew Taronne'a."," - SWAT przybywa na miejsce. Zabezpieczenie terenu i zajecie pozycji przez snajperow."," - Otaczajacy teren policjanci wywoluja przebywajacych w srodku, lecz nie otrzymuja odpowiedzi."," - Po kilku godzinach braku kontaktu podjeta zostaje decyzja o wejsciu grupy szturmowej.")
LoadingText=2189 Carrols Road, siedziba Dzieci Taronne'a

[SP-Office]
PrimarySpawnPoint=Main Entrance
SecondarySpawnPoint=Rear Entrance
CampaignObjectiveHostageSpawn=("Rita Winston")
MissionDescription=("Barricaded Suspects","Government Plaza, Offices of the Department of Agriculture, 2112 Geddy Avenue","August 31 - 18:05")
BriefingText=("|Okay, quiet down and listen.   ","|The Department of Agriculture has its local offices in the Government Plaza on Geddy Avenue. Approximately 50 minutes ago the building was entered by a group of suspects armed with assault rifles and Improvised Explosive Devices, IEDs.","|It appears their plan was to raid the office, plant the bomb and then escape, but someone messed up. The bomb detonated prematurely causing a fire on the lower floor. The fire department attended and tried to contain the fire, but they didn't realize the bad guys were holding hostages on the upper floors. When the fire crew were shot at, they retreated and called the local precinct who called the negotiation team.","|It seems these guys are local farmers who have a beef with the government's policies on genetically-modified crops. They appear far better armed than your average farmer. Spotters have reported seeing them carrying M1s and wearing body armor - somebody has sold them their gear, probably the same somebody who sold them the explosives they used.","|The negotiators haven't made much headway here. They've traded two hostages for two gas masks, but other than the occasional anti-government rant, contact with the suspects has been minimal.","|They haven't made any direct threats against the hostages but we're assuming their intent was to empty the building and then destroy it. But considering the clumsiness of their actions so far, we're not waiting for them to make another mistake and get someone killed.","|Choose your gear and get ready to deploy.")
LocationInfoText=("Government Plaza, Offices of the Department of Agriculture, 2112 Geddy Avenue","The Department of Agriculture office is part of the Government Plaza. The building dates from the nineteen-fifties and has been retro-fitted several times. Offices dominate the top and middle floors, while the basement houses parking and utilities areas.")
HostageName=("Rita Winston","Unknown")
HostageVitals=("Sex:Female|Descent:Caucasian|Height:5'6''|Weight:160|Hair:Blonde|Eyes:Blue|DOB:1969|Age:37","Information Unavailable")
HostageDescription=("Rita Winston is a section supervisor with the Department of Agriculture. Our concern is that if the terrorists realize she holds some departmental power, they may single her out for retribution.","")
SuspectName=("Unknown")
SuspectVitals=("Information Unavailable")
SuspectDescription=(" ")
EntryOptionTitle=("Side 1, Level 1","Side 3, Level 1")
EntryDescription=("Main Entrance","Rear Entrance")
TimeLinePlot=(0,10,30,20,70,100)
TimeLineTime=("17:12","17:19","17:26","17:41","17:48","17:59")
TimeLineShortDescription=("Suspects Enter Building."," Bomb Detonates.","Police Units Arrive.","Fire Crews Arrive.","Rescue Crew Fired Upon, SWAT Called.","Tactical entry begun")
TimeLineLongDescription=(" - A group of suspects armed with assault rifles and Improvised Explosive Devices enters building"," - One of the bombs detonates prematurely causing a fire on the lower floor."," - First police units arrive."," - Fire Crews Arrive."," - Fire under control, rescue crew fired upon."," - Swat officers make tactical entry ")
LoadingText=2112 Geddy Ave., The Department of Agriculture

[SP-Hospital]
PrimarySpawnPoint=Podejscie do glownego holu
SecondarySpawnPoint=Hol
CampaignObjectiveHostageSpawn=("Hyun-Jun Park")
MissionDescription=("Szybki szturm","691 87th Street","12 kwietnia, godz. 00:34")
BriefingText=("Sluchajcie uwaznie, mamy na glowie problem, ktory moze byc poczatkiem konfliktu miedzynarodowego. Koreanski dyplomata, Hyun-Jun Park, zostal napadniety przez szesciu nieznanych sprawcow w poblizu restauracji. W wyniku strzelaniny pan Park zostal ranny. Ochroniarze przetransportowali go w bezpieczne miejsce, choc nie udalo im sie pojmac ani jednego napastnika. W obecnej chwili Park przebywa w szpitalu sw. Michala, na oddziale intensywnej terapii. Jako ze nie mielismy dosc czasu, by zabezpieczyc teren szpitala, musielismy wyrazic zgode, aby ochrona pana Parka towarzyszla mu na oddziale.","|Pan Park jest jednym z wyzszych ranga urzednikow, pracujacych w ambasadzie Poludniowej Korei. W ciagu ostatnich dwoch dni wystepowal na forum Organizacji Narodow Zjednoczonych, poruszajac kwestie zjednoczenia kraju, ktorego jest goracym zwolennikiem. Poniewaz Hyun-Jun Park jest jednym z kluczowych czlonkow delegacji, zakladamy, ze atak mial podloze polityczne, ale nie wiemy jeszcze, kto mogl za nim stac. Jedno jest pewne - napastnicy nie byli zwyklymi przestepcami, na co wskazuja uzywany przez nich sprzet i doskonala organizacja. Park zostal zaatakowany, gdy znajdowal sie w miejscu niezwiazanym z wizyta dyplomatyczna..","|W obecnej chwili szpital sw. Michala zostal zaatakowany przez grupe uzbrojonych ludzi, prawdopodobnie tych samych, ktorzy wczesniej dokonali ataku na Parka. Jak poprzednio, sa dobrze uzbrojeni i swietnie zorganizowani. Nie maja zamiaru brac zakladnikow i zrobi a wszystko, zeby wykonac zadanie. Wybierzcie punkt wejscia, wezcie sprzet i w droge!")
LocationInfoText=("691 87th Street","Szpital sw. Michala. Szpital jest starym budynkiem, ktory niedawno zostal zmodernizowany i lekko przebudowany. Niestety, uklad terenu uniemozliwia skuteczne rozmieszczenie strzelcow wyborowych.")
HostageName=("Hyun-Jun Park")
HostageVitals=("Plec: Mezczyzna|Rasa: Zolta|Wlosy: Czarne|Oczy: Brazowe|Wzrost: 170 cm|Waga: 72 kg|Data ur.: 08/22/1947|Wiek: 61")
HostageDescription=("Wysoko postawiony poludniowokoreanski dyplomata. Ranny w wyniku wczesniejszego ataku.")
SuspectName=("Nieznany")
SuspectVitals=("Cechy: Nieznane")
SuspectDescription=("Nieznana liczba dobrze uzbrojonych napastnikow dokonala ataku na szpital.")
EntryOptionTitle=("Strona 1, Poziom 1","Strona 3, Poziom 1")
EntryDescription=("Podejdz do glownego foyer","Przejdz do holu od strony skrzydla badawczego")
TimeLinePlot=(0,10,90,92,100)
TimeLineTime=("22:20","22:33","00:20","00:23","00:34")
TimeLineShortDescription=("Atak na dyplomate","Hyun-Jun Park w szpitalu","Szpital zaatakowany","SWAT wyslany","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Atak na dyplomate i jego ochrone; Hyun-Jun Park ranny, zostaje przewieziony do szpitala sw. Michala."," - Hyun-Jun Park przyjety do szpitala."," - Napastnicy atakuja szpital; wlaczony zostaje alarm."," - Oddzial SWAT zostaje wyslany na miejsce zdarzenia z poleceniem przeprowadzenia natychmiastowej akcji. "," - Oddzial SWAT przybywa na miejsce i natychmiast wkracza do akcji, zeby jak najszybciej przywrocic porzadek.")
LoadingText=691 87th Street, szpital sw. Michala

[SP-ArmsDeal]
PrimarySpawnPoint=Dziedziniec
SecondarySpawnPoint=Boczna uliczka
CampaignObjectiveEnemySpawn=("Hadeon Koshka","Clark Jennings")
MissionDescription=("Dzialanie podwyzszonego ryzyka","1302 Blakestone Avenue","25 kwietnia, godz. 23:47")
BriefingText=("Biuro ds. Zwalczania Przestepczosci Zorganizowanej ma cos dla nas. Od ponad roku jego funkcjonariusze rozpracowywali siatke przemyt nikow, ktory dostarczaja do miasta znaczne ilosci broni palnej, i nareszcie trafili na jakis porzadny trop. Glownym podejrzanym jest niejaki Hadeon Koshka, obywatel ukrainski, czesto odwiedzajacy Stany Zjednoczone. Jego wizyty zbiegaja sie z pojawieniem sie wiekszych ilosci rosyjskiej broni na czarnym rynku.","|Dzis kolej na nas. Detektyw Clark Jennings spedzil ostatnie dwa miesiace na rozpracowaniu organizacji Koschki od srodka i dzis przekazal do Biura informacje o planowanym spotkaniu. Transakcja ma zostac przeprowadzona w opuszczonym domu numer 1302 przy Blakestone Avenue. Detektyw Jennings przekazal dane tak szybko, jak mogl, jednak nie mamy czasu, by wezwac ludzi z ATF. Co prawda, handel bronia to ich dzialka, ale tym razem to my znalezlismy sie na wlasciwym miejscu i o wlasciwej porze.","|Szczypta historii. Zwiazek Radziecki mial duzo skladow broni i baz woskowych w roznych miejscach. Po jego upadku, wiele z tych skladow albo 'zniknelo' albo zostalo porzuconych. Handel bronia, zarowno legalny jak i ten z czarnego rynku, jest istotnym zrodlem dochodu dla tego regionu, a lokalne wladze nie moga sie zdecydowac czy go zatrzymac czy nie. Tak wiec to od nas zalezy, czy ta bron przestanie pojawiac sie na naszych ulicach.","|Spotkanie ma sie odbyc pod adresem 1320 Blakestone, w porzuconym budynku HUD. Nie mamy jego planu, ale za to mamy plany okolicy, dzieki pomocy Jennigs'a. Koshka powinien byc w pokoju ze skladem broni, razem ze swoim klientem .Wiele jest tu do stracenia - dlatego oczekujemy ze obydwie grupy zabiora ze soba wsparcie. Spodziewajcie sie uzbrojonych i niebezpiecznych podejrzanych zarowno w budynku jak i przed nim. Detektyw Jennings bedzie w ukryciu. Nie bedzie mogl sie ujawnic w sposob bezpieczny, dopoki nie przejmiecie kontroli nad sytuacja, tak wiec miejcie na niego oko. Przyjrzyjcie sie waszym celom dokladnie, wybierzcie sprzet i szykujcie sie.")
LocationInfoText=("1302 Blakestone Ave, dawna siedziba Wolcott Projects","|Prace rozbiorkowe zostaly przerwane po wykupieniu budynku przez Koschke i jego wspolnikow. Sam Koschka powinien przebywac w tylnej czesci budynku, zas jego ludzie moga znajdowac sie na calym terenie. Do budynku prowadzi kilka dobrze dostepnych wejsc, miedzy innymi: drzwi glowne, wejscie przez piwnice (strona 4, poziom 0) oraz przez rozebrana czesc budynku (strona 3, poziom 1).","|Mamy dwa dobrze kryte miejsca dla ewentualnego wsparcia: Sierra Jeden moze oslaniac pomieszczenie, w ktorym dojdzie do transakcji (strona 3, poziom 1), zas Sierra Dwa moze oslaniac strone 4, poziom 2.")
HostageName=("Clark Jennings")
HostageVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Czarne|Oczy: Niebieskie|Wzrost: 180 cm|Waga: 88 kg|Data ur.: 08/20/72|Wiek: 36")
HostageDescription=("Detektyw Jennings znajduje sie wewnatrz gangu jako jeden z ludzi Koschki. Bedzie uzbrojony i nie mozemy przewidziec jego zachowania, wiec uwazajcie.")
SuspectName=("Hadeon Koshka")
SuspectVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Brazowe|Oczy: Niebieskie|Wzrost: 5' 11|Waga: 180|Data ur.: 22/03/63|Wiek: 45")
SuspectDescription=("Hadeon Koshka jest obywatelem Ukrainy. Podejrzany o przewodzenie grupie przemytnikow i handlarzy, sprzedajacych na czarnym rynku bron ze starych magazynow radzieckich.")
EntryOptionTitle=("Strona 1, Poziom 1","Strona 2, Poziom 1")
EntryDescription=("Dziedziniec.","Boczna uliczka.")
TimeLinePlot=(0,83,100)
TimeLineTime=("13:12","22:00","23:47")
TimeLineShortDescription=("Dostarczenie informacji","Przybycie SWAT","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Detektyw Jennings informuje, ze dzis o godzinie 23:45 ma sie odbyc transakcja. Biuro ds. Zwalczania Przestepczosci Zorganizowanej wydaje nakaz aresztowania. Brygada SWAT powiadomiona."," - SWAT przybywa na miejsce. Dyskretne zabezpieczenie terenu i rozmieszczenie snajperow."," - Rozpoczecie transakcji. Wyslanie grupy szturmowej.")
