EntryDescription=("Wejscie serwisowe","Drzwi ewakuacyjne")
TimeLinePlot=(0,20,100)
TimeLineTime=("16:26 ","16:33 ","16:51")
TimeLineShortDescription=("Polaczenie 911","Pierwsze jednostki na miejscu","Rozpoczecie akcji taktycznej")
TimeLineLongDescription=("- 911 od wlasciciela Funtime, zgloszenie strzalow.","- Radiowozy na miejscu, perymetr.","- SWAT wchodzi natychmiast.")
