[SP-AutoGarage]
PrimarySpawnPoint=Wejscie na parking
SecondarySpawnPoint=Dach
CampaignObjectiveHostageSpawn=("Gary Altman")
MissionDescription=("Szturm / Odbicie zakladnikow","487 29th Avenue","5 stycznia, godz. 03:45")
BriefingText=("Oto, co wiemy. Wezwano nas do szybkiej akcji na terenie Centrum Samochodowego Victory Imports, na rogu 29. i Arligton. Wyglada na to, ze po nieudanej probie kradziezy samochodu zlodzieje zabarykadowali sie w srodku.","|Policjanci, ktorzy zostali wezwani na miejsce przestepstwa telefonicznie, przeszkodzili w kradziezy, jednakze zlodzieje otworzyli do nich ogien, po czym uciekli do budynku. Nie znamy ich dokladnej liczby, lecz wspomniani funkcjonariusze mowia o co najmniej czterech mezczyznach. Wszyscy sa uzbrojeni, niektorzy moga miec bron automatyczna. Wiemy, ze wzieli zakladnika, niejakiego Gary'ego Altmana, mechanika. To wlasnie on wezwal policje, ale polaczenie zostalo przerwane, zas proby dalszego kontaktu nie daly rezultatu.","|Obecnie nie jestesmy pewni gdzie ukrywaja sie podejrzani. Patrol doniosl o mlodych mezczyznach, w wieku przed i po 20 roku zycia, o jasnej karnacji, ubranych w uliczne ciuchy: dzin sy i koszule - ale nie mamy wystarczajacych dowodow aby to potwierdzic. Jesli chodzi o M.O., ta kradziez jest czyms nowym. W zadnym lokalnym garazu nie odnotowano podobnych napadow. Wyglada na to, ze bedziemy musieli stlumic to w zarodku. ","| Patrol probowal ich wywolywac, ale nie otrzymal zadnej odpowiedzi oprocz odglosow broni. Jednak gdy negocjatorzy nawiaza z nimi kontakt, powinni byc bardziej sklonni do rozmowy. Zazyczyli sobie jedzenia i kamizelek, ale obydwa zadania zostaly odrzucone poniewaz albo nie chcieli lub nie mogli uwolnic Altmana. O 03:30 podejrzani wystosowali ultimatum w ktorym zadali mozliwosci odejscia w spokoju. Dalsze negocjacje z podejrzanymi staly sie krotsze i bardziej ostre. Negocjacje sa w impasie, poniewaz chodzi tu o bezpieczenstwo Altmana, a wyglada na to ze podejrzani staja sie coraz bardziej zdesperowani. Czas na zakonczenie tej zbyt dlugo trwajacej sytuacji.")
LocationInfoText=("487 29th Avenue","|Na nizszym poziomie znajduja sie warsztaty i parking. Pietro przeznaczone jest najprawdopodobniej na biura. Mozemy wejsc albo z gory, przez dach, albo z dolu, przez podziemny parking.","|Snajperzy obserwuja dach.")
HostageName=("Gary Altman")
HostageVitals=("Plec: Mezczyzna|Rasa: Biala|Wzrost: 178 cm|Waga: 95 kg|Wlosy: Brak|Oczy: Brazowe|Data ur.: 03/12/1972|Wiek: 36")
HostageDescription=("Mechanik w firmie Victory Imports. Zglosil probe kradziezy samochodu. Prawdopodobnie przebywa w ktoryms z biur.")
SuspectName=("Nieznany")
SuspectVitals=("Informacja niedostepna")
SuspectDescription=("")
EntryOptionTitle=("Strona 1, Poziom 0","Dach")
EntryDescription=("Polnocny wjazd na parking","Drzwi na dach")
TimeLinePlot=(0,2,4,9,14,19,27,73,87,100)
TimeLineTime=("01:19","01:23","01:27","01:35","01:42","01:50","02:02","03:10","03:30","03:45")
TimeLineShortDescription=("Zgloszenie","Potwierdzona obecnosc podejrzanych","Zabezpieczenie terenu","Przybycie SWAT","Okraznie i wywolanie","Negocjatorzy nawiazuja kontakt","Zadanie: Umozliwienie ucieczki","Zadanie: Kamizelki kuloodporne","Zagrozenie zakladnikow","Podjecie szturmu")
TimeLineLongDescription=(" - Zgloszenie proby kradziezy samochodu w Centrum Samochodowym Victory Imports. Woz 32 Adam wyslany na miejsce zdarzenia."," - 32 Adam zglasza kontakt z kilkoma uzbrojonymi napastnikami."," - Policjanci zabezpieczaja teren, powiadomiona zostaje brygada SWAT."," - SWAT przybywa na miejsce zdarzenia. Snajperzy i druzyny ubezpieczenia zajmuja pozycje."," - Wezwanie napastnikow do poddania sie. Brak odpowiedzi."," - Brygada kryzysowa kontaktuje sie z napastnikami telefonicznie"," - Napastnicy domagaja sie umozliwienia im odejscia do 04:00."," - Napastnicy zad a kamizelek kuloodpornych. Zadanie odrzucone."," - Napastnicy ponawiaja zadanie swobodnego odejscia do 04:00, grozac zabiciem zakladnika. "," - Decyzja o podjeciu szturmu. Grupa szturmowa zebrana.")
LoadingText=487 29th Avenue, Centrum Samochodowy Victory Imports

[SP-HalfwayHouse]
PrimarySpawnPoint=Front Entrance
SecondarySpawnPoint=Delivery Entrance
CampaignObjectiveHostageSpawn=("Lionel Macarthur")
MissionDescription=("Barricaded Suspects","Our Sisters of Mercy Halfway House: 796 Newbury St.","August 15 - 11:32")
BriefingText=("Let me have your attention team. About two hours ago a group of armed men attempted to rob the post office at the corner of Watts and Lonsdale. They were confronted by an armed security guard and when he opened fire, they ran.  ","|The guard called 911 and a nearby patrol car responded, spotting the suspects on foot on Newbury St. Seems their getaway driver panicked and drove off without them. When the officer ordered them to surrender they opened fire and retreated into a halfway house, Our Sisters of Mercy.","|The halfway house provides temporary accommodation for older men, often just out of prison or recently released from mental care. A few of the residents fled once the gunmen entered, but one of the sisters who runs the house says at least six people are unaccounted for. That means any civilians inside may be confused, scared and uncooperative. Check your targets carefully.","|The suspects appear well armed but disorganized. The security guard reported seeing at least five individuals carrying automatic rifles and shotguns, and says they may have been wearing body armor. The word on the street is that it's the Stetchkov clan who've provided the guns, but they don't normally handle firearms.","|The police negotiator has been trying to communicate with the suspects, but as yet they haven't responded. There's been some sporadic gunfire from within the building, which is why we're going in.","|Suit up and get ready.")
LocationInfoText=("Our Sisters of Mercy Halfway House ","|Our Sisters of Mercy have been running the halfway house on Newbury for more than 40 years. The building was originally a small brewery constructed in the 1920s. Following the depression the building sat unused until the 1960s when it was donated to the local convent. The sisters converted the downstairs into kitchen and recreation areas, and the upstairs into temporary accommodation for homeless men. The original brewing floor was turned into a chapel.")
HostageName=("Lionel Macarthur")
HostageVitals=("Sex:Male|Descent:Caucasian|Height:5'7''|Weight:165|Hair:Grey|Eyes:Brown|DOB:1931|Age:75")
HostageDescription=("Macarthur is a long-term senior resident in the halfway house. The sisters who run the house are particularly worried about him as he needs frequent medication and monitoring.")
SuspectName=("Unknown")
SuspectVitals=("Information unavailable")
SuspectDescription=("The security guard reported seeing at least five individuals carrying automatic rifles and shotguns, and says they may have been wearing body armor. ")
EntryOptionTitle=("Side 1, Level 1","Side 3, Level 1")
EntryDescription=("Front Entrance","Delivery Entrance")
TimeLinePlot=(0,18,35,100)
TimeLineTime=("9:04","9:22","9:47","11:32")
TimeLineShortDescription=("911 Call","First Units Arrive"," CNT Attempts Contact ","Shots Heard - Tactical entry begun")
TimeLineLongDescription=(" - 911 emergency call received from post office guard."," - Patrol officers arrive and establish containment perimeter.  SWAT and CNT notified."," - CNT (Crisis Negotiation Team) attempts contact without response.","  - Shots fired. Decision made to go tactical.")
LoadingText=796 Newbury St., Our Sisters of Mercy

[SP-ABomb]
PrimarySpawnPoint=Front Entrance
SecondarySpawnPoint=Service Entrance
MissionDescription=("Rapid Deployment","1536 Adelaide Avenue","December 12 - 23:42")
BriefingText=("We're being called up for a rapid deployment at an ongoing shots fired situation at the A-Bomb nightclub.  At least four gunmen, likely more, are exchanging shots with each other.  They don't appear to be actively attacking civilians, or attempting to hold hostages, although we have reports that there are multiple wounded victims from crossfire.  Witness reports are confused, and in some cases conflicting.","|We have both Caucasian and Hispanic shooters, shooting along racial lines.  All of them appear to be young adult males.","|We have two possible entries: the front door, past the ticket booth, and a back alley loading zone.  We have a rough sketch of the layout from an off-duty bartender; give it a once over, but don't trust it too much.","|Most of the patrons made it out; however, there are still civilians holed up in there.   We know some of them are wounded from witness reports. The perimeter is still reporting sporadic gunfire inside, and the paramedics won't go in until we've cleared the building.  You need to get in there and bring order to chaos by locating and arresting the gunmen.  In addition, you need to locate and secure for evacuation all remaining civilians, especially the wounded.  Review the information, choose your entry, and get your gear together.  It's time to go to work.")
LocationInfoText=("1536 Adelaide Avenue","There is both a main and a secondary stage on the first floor, and both stages have an attached bar area. There is a second floor with a manager's office and an additional lounge. The map is sketchy at best, but it is the only information about layout available.||High ground is covering your approach, while Sierra One is covering a storage room.")
HostageName=("Unknown")
HostageVitals=("Information Unavailable")
HostageDescription=("")
SuspectName=("Unknown Latinos","Unknown Caucasians")
SuspectVitals=("Vitals unknown","Vitals unknown")
SuspectDescription=("Members of a gang. Latin descent.","Members of a gang.  Caucasian descent.")
EntryOptionTitle=("Side 2, Level 1","Side 1, Level 1")
EntryDescription=("Service Entrance, off of side alley","Front Entrance")
TimeLinePlot=(0,20,100)
TimeLineTime=("23:27","23:30","23:42")
TimeLineShortDescription=("Shots fired; 911 Calls","Perimeter established","SWAT arrives")
TimeLineLongDescription=(" - First 911 calls logged reporting shooting at the club.  SWAT notified."," - Patrol Units arrive on scene and begin to set up a perimeter and perform first aid on initial victims.  Patrol radios for ambulances."," - SWAT arrives on scene.  Due to ongoing live fire, SWAT immediately goes tactical to neutralize the situation.")
LoadingText=1536 Adelaide Ave., The A-Bomb

[SP-Casino]
PrimarySpawnPoint=Back Door
CampaignObjectiveEnemySpawn=("Louie Baccus","Simon Grover","Allen Kruse")
CampaignObjectiveHostageSpawn=("Jeremy Walsh")
MissionDescription=("High Risk Warrant Service","1092 Westfield Road","February 24 - 17:32")
BriefingText=("This one's a little sticky.  Vice has been keeping an eye on Northside Vending and Amusements for the last three or four weeks.  They've been  building a case against an alleged bookmaking operation going on in the basement of the business.  Undercover detective Jeremy Walsh has been working closely with the suspects, and today received an invitation to enter the bookmaking area.","|All went smoothly until Walsh was out of sight. Walsh's wire reported that he was still talking to the suspects, who showed no evidence of suspecting him.  Less than ten minutes later, there was a sudden burst of static, and then Walsh's wire went dead.  If everything was going as expected, Walsh would already be back, since he was supposed to go in, place one bet, and come right back out.  With no way to determine Walsh's actual state, we're assuming he's in danger and it's time to go in after him.   ","|We know at least three individuals are present.  The first, Louie Baccus, is the owner of the business.  The other two are Allen Kruse and Simon Gowan.  Kruse and Gowan are believed to be the movers behind the bookie operation, with Baccus providing cover and space.  Vice believes there are additional suspects inside, acting as bookies and runners.  Numbers are unknown, but could go as high as ten suspects total. That's one reason Walsh was sent in, to determine the exact number of players.    ","|Kruse and Gowan have extensive records, ranging from petty larceny to assault with a deadly weapon.  Assume both are armed and dangerous.  Baccus is an unknown, but given his compatriot's histories, better to assume he is armed as well.  Note that Walsh's last recorded statement was one of surprise at ''the size of your setup.''  Sounded like he was impressed, which can't mean anything too good for us. ","|We have a layout for the shop, but we don't have anything on the basement.  We know it's accessed through the storage areas, but we don't know anything about the bookie's territory.  We know it's accessed through the storage areas, but we don't know anything about the bookie's territory.  Keep your eyes open; there could be any number of surprises.  Time to get Detective Walsh out, and get the suspects under control.   Choose your gear carefully and move out. ")
LocationInfoText=("Northside Vending and Amusements, 1092 Westfield Road","|Sierra One has coverage on Side 3, Level 1; they report a large warehouse-type room.")
HostageName=("Jeremy Walsh","Louie Baccus")
HostageVitals=("Sex: Male|Descent: Caucasian|Hair: Brown|Eyes: Brown|Height: 5' 10''|Weight: 180|DOB: 12/08/70|Age: 38","Sex: Male|Descent: Caucasian|Hair: Black|Eyes: Blue|Height: 5' 11''|Weight: 190|DOB: 10/15/1968|Age: 40")
HostageDescription=("Detective Walsh has been working undercover in the Mafia for quite some time and is a reliable source of information about mob operations.","Owner of Northside Vending and Amusements.  Baccus has never been arrested, but is suspected to have ties to organized crime.")
SuspectName=("Allen Kruse","Simon Gowan")
SuspectVitals=("Sex: Male|Descent: Caucasian|Hair: Brown|Eyes: Blue|Height: 5' 10''|Weight: 150|DOB: 01/02/1964|Age: 44","Sex: Male|Descent: Caucasian|Hair: Light Brown|Eyes: Blue|Height: 6' 2''|Weight: 210|DOB: 07/29/1979|Age: 29")
SuspectDescription=("Appears almost daily at the Northside Vending. Has been convicted of illegal possession of firearms and simple assault.  Arrested for racketeering, but not convicted.  ","A regular at the Northside Vending. Has been convicted of assault with a deadly weapon and robbery.")
EntryOptionTitle=("Side 3, Level 1")
EntryDescription=("Back door into the establishment.")
TimeLinePlot=(0,42,71,88,98,100)
TimeLineTime=("14:03","15:30","16:30","17:05","17:28","17:32")
TimeLineShortDescription=("Walsh checks in","Walsh's wire signal lost","Walsh's Lieutenant briefed","Warrants issued","SWAT arrives","Tactical entry begun")
TimeLineLongDescription=(" - Detective Walsh checks in with his handler and notifies him that he will be entering the shop at 12:45."," - Walsh's wire suddenly goes to static with no clear indication of what the malfunction is."," - Lieutenant Collins is briefed of the situation and the missed call.  All officers involved believe Walsh has been made.  DA is notified."," - Arrest warrants are issued.  SWAT dispatched to scene."," - Containment perimeter and high ground established."," - Decision made to go tactical. Entry team assembled.")
LoadingText=1092 Westfield Rd., Northside Vending and Amusements

[SP-RedLibrary]
PrimarySpawnPoint=Wejscie frontowe
SecondarySpawnPoint=Wejscie do garazu
CampaignObjectiveHostageSpawn=("Warren Rooney")
MissionDescription=("Szturm / Odbicie zakladnikow","732 Gridley Street","25 stycznia, godz. 18:05")
BriefingText=("Kilka minut po godzinie 14:00 kilku uzbrojonych napastnikow wdarlo sie do pomieszczen biurowych w Wainwright Mill Center. Ostrzelujac wszystko przeszli przez kilka biur, az w koncu zostali okrzeni w jednym z nich przez interweniujacych policjantow. ","|S1 to prawdopodobnie ci sami ludzie, ktorzy niedlugo przedtem probowali dokonac napadu na bank Community Savings and Loans. Chociaz uruchomili alarm wzywajacy straznikow i policje, nie zrezygnowali z prob wlamania i zostali zatrzymani dopiero przez straznikow sejfu.","|Podczas strzelaniny zabili dwoch z nich, po czym zbiegli z miejsca przestepstwa. Uciekajac przed policja, rozbili swoj samochod w poblizu Wainwright Mill Center i ukryli sie w biurach Red Library Inc. Policja zrezygnowala z kontynuowania poscigu i zabezpieczyla teren.","Red Library to informatyczna firma specjalizujaca sie w przechowywaniu danych. Pracownicy czesto pracuja w soboty, wiec spodziewamy sie, ze to bylo pierwsze niezamkniete biuro, ktore dostrzegl przestepcy. Niestety to oznacza, ze w biurze byli pracownicy kiedy weszli.","| Negocjatorzy rozmawiali z nimi od 15:30. Zakladamy iz mimo ze napastnicy sa ciezko uzbrojeni, to nie wiedza co robia. Jak dotad domagali sie trasy ucieczki oraz pieciu milionow dolarow w zamian za 'licznych wiezniow'. Negocjatorom udalo sie wydostac czterech zakladnikow w zamian za dwie maski gazowe oraz dwie kamizelki kuloodporne. Uwolnieni zakladnicy nie potrafia jednakze udzielic nam informacji o liczbie zakladnikow, poniewaz nikt tak naprawde nie wie ile osob dzis pracowalo. Ostatnio slysane strzaly wskazuja na to, ze czas wkroczyc do akcji i uratowac reszte zakladnikow.")
LocationInfoText=("732 Gridley Street, Red Library Inc","|Dlugi impas w negocjacjach pozwolil nam na zdobycie planow budynku. Zwolnieni zakladnicy przekazali nam spora ilosc informacji na temat zagospodarowania przestrzeni biurowej.","|Sierra Jeden ma w polu widzenia pomieszczenia socjalne (strona 2, poziom 3); Sierra Dwa oslania budynek od strony 4 na poziomie 3.")
HostageName=("Warren Rooney")
HostageVitals=("Plec: Mezczyzna|Rasa: Biala|Wlosy: Brazowe|Oczy: Piwne|Wzrost: ok. 180 cm|Waga: ok. 80 kg|Data ur.: Nieznana|Wiek: ok. 45")
HostageDescription=("Prezes zarzadu firmy Red Library Inc. Pracownicy mowia, ze jest surowym, lecz sprawiedliwym pracodawca.")
SuspectName=("Nieznany")
SuspectVitals=("Cechy: Nieznane")
SuspectDescription=("Wielu dobrze uzbrojonych podejrzanych.")
EntryOptionTitle=("Strona 1, Poziom 1","Strona 4, Poziom 0")
EntryDescription=("Przy recepcji znajduje sie osloniete wejscie boczne.","Wejscie przez parking znajdujacy sie ponizej biur.")
TimeLinePlot=(0,9,11,13,17,24,57,98,100)
TimeLineTime=("14:02","14:24","14:30","14:34","14:45","15:03","16:22","18:03","18:05")
TimeLineShortDescription=("Zauwazono uzbrojonych napastnikow","Przybycie SWAT","Negocjatorzy nawiazuja kontakt","Pierwsze zadanie","Wymiana zakladnikow","Koniec terminu","Wymiana zakladnikow","Strzaly","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Uzbrojeni ludzie wchodza do budynku."," - SWAT przybywa na miejsce. Zabezpieczenie terenu i rozmieszczenie snajperow."," - Negocjatorzy nawiazuja kontakt z porywaczami, ale nie uzyskuja zadnych danych."," - Porywacze zad a 5 milionow dolarow i smiglowca do godziny 15:00."," - Dwaj zakladnicy zostaja zwolnieni w zamian za dwie kamizelki kuloodporne."," - Negocjatorzy przekonuja porywaczy, ze ich pierwsze zadanie bylo nonsensowne. Porywacze zad a transportera opancerzonego. Termin zostaje przesuniety na 18:00."," - Chcac zyskac na czasie, negocjatorzy decyduja sie przekazac porywaczom maski przeciwgazowe w zamian za kilku zakladnikow. Porywacze wykazuja oznaki zmeczenia i rozdraznienia."," - Podczas rozmowy telefonicznej z negocjatorami porywacze groza zakladnikom. Mozliwe, ze wsrod zakladnikow sa ranni. Kontakt zostaje zerwany, slychac odglosy strzalow. Zapada decyzja o szturmie."," - Strzelanina nie ustaje, druzyna rozpoczyna szturm.")
LoadingText=732 Gridley Street, Red Library Inc.

[SP-Backstage]
PrimarySpawnPoint=Main Entrance
SecondarySpawnPoint=Rear Loading Dock
CampaignObjectiveEnemySpawn=("Andrew Norman")
MissionDescription=("Hostage Rescue","The Sellers Street Auditorium, 1801 Sellers St","August 26 - 20:49")
BriefingText=("Listen up. Approximately 45 minutes ago a group known as Citizens Against Satanic Music or 'CASM' stormed a rock concert at the Sellers Street Auditorium. They fired a barrage of shots injuring several audience members and creating a panic. The band, called ''Devil's Playthings'', fled the stage but was closely followed by the suspects. They claim to now have the band hostage.   ","|CASM have long been a vocal opponent of rock music, occasionally clashing with police during protests, but they've never resorted to this level of violence before. They've been sending the band hate mail for some time, and it looks like the band's latest album ''Die For The Devil'' pushed them over the edge. They want it taken off store shelves.","|These guys aren't hardened criminals - they're sloppy and badly organized, but they're also extremely well equipped. Looks like somebody sold them some guns and they got delusions of grandeur.","|Witnesses report seeing at least four suspects armed with automatic weapons and wearing disguises. We're guessing there are several civilians inside either injured or hiding. We're taking the suspects claim that they're holding the band hostage seriously. These guys are nervous amateurs and that makes them more likely to hurt or kill an innocent civilian, either deliberately or accidentally.","|Choose your equipment and be ready to move out.")
LocationInfoText=("The Sellers Street Auditorium, 1801 Sellers St","|The Seller's Street Auditorium was built in 1983 to cater for local bands and theater groups. The lower level consists of the front-of-house area with ticket booths, the stage and audience pit. The upper level contains dressing rooms, storage areas and stage access and maintenance spaces, as well as offices and the auditorium's bar/restaurant.")
HostageName=("Unknown")
HostageVitals=("Information Unavailable")
HostageDescription=("")
SuspectName=("Andrew Norman","Unknown")
SuspectVitals=("Sex:Male|Descent:Caucasian|Height:5'6''|Weight:200|Hair:Blonde|Eyes:Brown|DOB:1962|Age:44","Vitals Unavailable")
SuspectDescription=("Norman is a known member of CASM and has misdemeanor convictions for mail fraud. He has frequently singled out Devil's Playthings on CASM's internet site. We believe he's a member of the gunmen."," ")
EntryOptionTitle=("Side 1, Level 1","Side 3, Level 1")
EntryDescription=("Main Entrance","Rear Loading Dock")
TimeLinePlot=(0,15,30,50,60,100)
TimeLineTime=("20:05","20:11","20:23","20:32","20:35","20:49")
TimeLineShortDescription=("Suspects Enter Auditorium","Patrol Cars Arrive","Perimeter Established"," CNT Arrive","Suspect Demands"," Shots Fired.")
TimeLineLongDescription=(" - Suspects enter the auditorium. Civilians flee."," - First responding patrol cars arrive."," - Perimeter Established"," - Negotiator arrives and attempts first contact."," - Suspects issue initial, conflicting demands."," - More shots heard from inside auditorium. SWAT enter.")
