HostageVitals=("Plec: Mezczyzna|Rasa: Kaukaska|Wzrost: 168 cm|Waga: 109 kg|Wlosy: Brazowe|Oczy: Brazowe|Rok ur.: 1958|Wiek: 48")
HostageDescription=("Bogard jest wlascicielem i mieszka nad lokalem. Dzwonil na 911 i moze byc uwieziony.")
SuspectName=("Imie: Javier Arias")
SuspectVitals=("Plec: Mezczyzna|Rasa: Kaukaska|Wzrost: 170 cm|Waga: 75 kg|Wlosy: Siwe|Oczy: Brazowe|Rok ur.: 1977|Wiek: 29")
SuspectDescription=("Lokalny diler z dluga kartoteka: napasc, wlamanie, posiadanie broni i przestepstwa narkotykowe.")
