TimeLineTime=("17:04","17:16","17:33")
TimeLineShortDescription=("911 Call"," First Units Arrive"," SWAT Enter")
TimeLineLongDescription=(" - 911 Call received and SWAT notified"," - First units arrive and perimeter established and confirmed."," - SWAT goes tactical ")
