[SP-FairfaxResidence]
PrimarySpawnPoint=Podworze
SecondarySpawnPoint=Ulica
CampaignObjectiveEnemySpawn=("Lawrence Fairfax")
CampaignObjectiveHostageSpawn=("Melinda Kline")
MissionDescription=("Dzialanie podwyzszonego ryzyka / Odbicie zakladnikow","25 Glendive Lane","23 pazdziernika, godz. 04:43")
BriefingText=("Sluchajcie dobrze, panowie, bo sprawa jest powazna. Naszym celem jest Lawrence Fairfax, glowny podejrzany w sprawie dotyczacej serii brutalnych morderstw. Na poczatek male wprowadzenie: w ciagu ostatnich 18 miesiecy zaginelo siedem studentek miejscowego uniwersytetu. Za kazdym razem, po dwoch-trzech tygodniach od znikniecia, znajdowano ich rozczlonkowane szczatki, noszace slady tortur. Zabojca dzialal bardzo ostroznie, gdyz naszym ekspertom nie udalo sie znalezc zadnych sladow jego DNA na cialach ofiar.","|W wypadku ostatniego morderstwa mielismy wiecej szczescia, gdyz pod paznokciami ofiary znaleziono slady DNA pasujace do profilu jednego z podejrzanych, wspomnianego Lawrence'a Fairfaksa.","|I tu zaczynaja sie problemy. 18 pazdziernika, okolo godziny 20:00, zgloszono zaginiecie kolejnej studentki, niejakiej Melindy Kline. Jezeli zostala porwana przez Fairfaksa, ktory dziala zgodnie z poprzednim modus operandi, dziewczyna byc moze wciaz zyje. Naszym glownym zadaniem jest uratowanie jej, dlatego tez ruszamy bez wczesniejszego ostrzezenia."," |Teraz troche informacji o naszym podejrzanym. Fairfax jest tymczasowo zatrudniony jako stolarz w miejscowym uniwersytecie. Nie jest notowany, jednak zapisy sadowe mowia o kilku wygaslych nalozonych na niego ograniczeniach. Byl podejrzany o kradziez przedmiotow z poprzedniego miejsca pracy. Przelozeni Fairfax�a nie mowia o nim wiele - byl cichym typem, nie rozmawial z nikim za czesto. Bywal w bibliotece prawnej kilkakrotnie, przede wszystkim w dni przed zaginieciem naszych trzech ostatnich ofiar, wlaczajac w to Melinde Kline. Wywiad policyjny nie przyniosl zadnych nowych informacji - jednak detektyw zdobyl probke DNA z zostawionej przez podejrzanego chusteczki. ","|Fairfax widzial sie z psychiatr a po zwolnieniu, jednak nie uzyskalismy dostepu do tych rozmow. Psychiatra ostrzegl nas, ze Fairfax mogl uzbroic miejsca, w ktorych przebywa - mozesz spodziewac sie pulapek, wiec miej sie na bacznosci, szczegolnie w miejscach prywatnych Fairfax�a. Podejrzany mieszka z samotna matka, Gladys Fairfax. Ze wzgledu na problemy zdrowotne matka rzadko opuszcza dom. Nie ma zadnych dowodow na to, ze jest ona zamieszana, jednak lepiej uwazaj."," |Panowie, sekundy moga zadecydowac o zyciu i smierci Melindy Kline. Rozpoznajmy sytuacje, wybierzmy ekwipunek i ruszajmy.")
LocationInfoText=("25 Glendive Lane","|Klasyczny dwupoziomowy dom mieszkalny z dwiema sypialniami i wspolna lazienka. Wiekszosc domow w okolicy zostala zbudowana w oparciu o ten sam projekt. Nasz plan powstal na podstawie planow sasiednich budynkow i powinien poprawnie oddawac uklad parteru. Piwnice sa zazwyczaj wykanczane przez wlascicieli, wiec niewiele mozna powiedziec o ukladzie piwnicy w tym konkretnym domu.")
HostageName=("Melinda Kline","Gladys Fairfax")
HostageVitals=("Plec: Kobieta|Rasa: Biala|Wzrost: 163 cm|Waga: 57 kg|Wlosy: Czarne|Oczy: Brazowe|Data ur.: 02/04/1988|Wiek: 20","Plec: Kobieta|Rasa: Biala|Wzrost: 158 cm|Waga: 75 kg|Wlosy: Siwe|Oczy: Brazowe|Data ur.: 05/29/1940|Wiek: 68")
HostageDescription=("Melinda Kline jest studentka II roku na wydziale prawa. W dniu 18 pazdziernika zgloszono jej zaginiecie. Ostatni raz widziano ja, gdy opuszczala budynek wydzialu, 17 pazdziernika o godzinie 19:45. Rodzina i znajomi zgodnie twierdza, ze znikniecie nie moze wynikac ze zwyklych przyczyn.","Gladys Fairfax jest wlascicielka mieszkania przy 25 Glendive Lane. Otrzymuje rente inwalidzka i ma powazne problemy ze zdrowiem.")
SuspectName=("Lawrence Fairfax")
SuspectVitals=("Plec: M�czyzna|Rasa: Bia�a|Wzrost: 175 cm|Waga: ok. 90 kg|Wlosy: Czarne|Oczy: Brazowe|Data ur.: 20/07/1980|Wiek: 28")
SuspectDescription=("Obecnie zatrudniony jako stolarz przy pracach remontowych na uniwersytecie. Typ odludka. Jego jedyna znana krewn a jest matka, Gladys Fairfax.")
EntryOptionTitle=("Strona 3, Poziom 1","Strona 2, Poziom 0")
EntryDescription=("Dojscie do tylnych drzwi od podworza.","Wjazd do garazu od ulicy.")
TimeLinePlot=(0,55,94,98,100)
TimeLineTime=("18 Paz","20:20","04:00","04:30","04:43")
TimeLineShortDescription=("Informacja o zaginieciu Melindy Kline","Znalezienie ciala","Identyfikacja DNA","Przybycie SWAT","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Zaginiecie Melindy Kline zgloszone przez jej wspollokatorke, Angele Karey. Zaginiona widziana ostatni raz, kiedy opuszczala budynek wydzialu 17 pazdziernika o godzinie 19:45. Przyjaciele twierdza, ze Melinda nie planowala zadnego wyjazdu."," - Szczatki Rachel Polson znalezione przez Emmeta Durana, pracownika budowlanego."," - Ekipa dochodzeniowa odkrywa pod paznokciami Rachel Polson obecnosc tkanki z DNA Lawrence'a Fairfaksa."," - SWAT przybywa na miejsce. Zabezpieczenie terenu, brak wsparcia ze strony snajperow."," - Zapada decyzja o podjeciu szturmu. Grupa szturmowa zebrana.")
LoadingText=25 Glendive Lane, dom Fairfaksow

[SP-FoodWall]
PrimarySpawnPoint=Rog bocznej uliczki
CampaignObjectiveEnemySpawn=("Alex Jimenez","Lian Niu")
MissionDescription=("Dzialanie podwyzszonego ryzyka","1572 Norman St.","8 pazdziernika, godz. 20:24")
BriefingText=("Spokoj panowie, zaczynamy odprawe. Wydzial Sledczy ds. Przestepczosci Zorganizowanej poswiecil duzo czasu na zorganizowanie tej akcji, my zas mamy pomoc w aresztowaniu. Przez ostatnie dwa tygodnie restauracja Food Wall byla pod scisla obserwacja. Mamy podstawy przypuszczac, ze jej wlasciciel, niejaki Lian Niu, doswiadczony rusznikarz, zajmuje sie rowniez nielegalnym handlem bronia. W tym konkretnym przypadku chodzi o wytwarzanie i sprzedaz magazynkow o duzej pojemnosci. Niu ma nad restauracja mieszkanie, w ktorym produkuje sprzet oraz dokonuje transakcji. Byl juz wczesniej podejrzany o nielegalny handel bronia, ale nie znaleziono zadnych dowodow. ","|Dziesiec minut temu detektyw Sheary zauwazyl, ze do restauracji wszedl niejaki Alex Jimenez, platny zabojca znany pod pseudonimem 'Majcher', powiazany z kolumbijska mafia, glowny podejrzany w wielu sprawach o zabojstwo z ostatnich 18 miesiecy. Jimenez jest najprawdopodobniej uzbrojony i na pewno niebezpieczny.","|Sheary przypuszcza, ze Jimenez wrocil do swych interesow, zlecajac wprowadzenie poprawek do karabinku przenosnego MAC-10, ktorego uzyto niedawno w zabojstwie. Chcemy miec nienaruszone dowody, dlatego Jimenez i Niu nie moga sie w zadnym sposobie dowiedziec o naszej akcji. Wlasciciele restauracji i jej pracownicy beda w budynku kiedy do niego wkroczycie. Jak zawsze, namierzycie cel. ","| Waszym priorytetem jest unikniecie zadania jakichkolwiek obrazen cywilom, potem zas zabezpieczycie karabin Jimeneza. Wydzial nie moze sie doczekac odbycia dlugiej rozmowy z Jimenezem i Niu - a karabin ten sprawi, ze beda oni nad wyraz rozmowni. Tak wiec przejrzyjcie dokladnie plany pietra, zaplanujcie swoje wejscie i przygotujcie sprzet.")
LocationInfoText=("1572 Norman Street, restauracja Food Wall","|Glowne wejscie prowadzi z ulicy wprost na sale. Dodatkowo jest jeszcze tylne wejscie,  z bocznej alejki do kuchni. Do obu mozna podejsc z punktu wejscia. Parter przeznaczony zostal na restauracje, z sala jadalna na przodzie i kuchnia na tylach. Laczy je korytarz z toaletami. Z tylu, w poblizu kuchni, powinny znajdowac sie schody wiodace do mieszkania Niu. Najprawdopodobniej zajmuje ono cale pietro. Bezposrednio nad kuchnia (strona 3, poziom 2) lezy sypialnia.")
HostageName=("Nieznany")
HostageVitals=("Informacja niedostepna")
HostageDescription=("")
SuspectName=("Alex Jimenez","Lian Niu")
SuspectVitals=("Plec: Mezczyzna|Rasa: Biala, Latynos|Wzrost: 178 cm|Waga: 85 kg|Wlosy: Brazowe|Oczy: Brazowe|Data ur.: 04/09/1977|Wiek: 31","Plec: Mezczyzna|Rasa: Zolta|Wzrost: 168 cm|Waga: 72 kg|Wlosy: Czarne|Oczy: Brazowe|Data ur.: 14/10/1974|Wiek: 34")
SuspectDescription=("Alex Jimenez, znany jako 'Majcher', jest poszukiwany za wielokrotne morderstwa. Ma powiazania z kolumbijskimi przemytami narkotykow, aczkolwiek nie wiemy, dla kogo pracuje w tej chwili.","Lian Niu jest wlascicielem restauracji Food Wall, choc zatrudnia zarzadce do prowadzenia dzialanosc i. Podejrzany o nielegalny handel i wyrob broni. Restauracja sluzy najprawdopodobniej jako pralnia pieniedzy.")
EntryOptionTitle=("Strona 1, Poziom 1")
EntryDescription=("Rog uliczki")
TimeLinePlot=(0,80,86,100)
TimeLineTime=("23 wrzesnia","19:42","19:55","20:24")
TimeLineShortDescription=("Wydanie nakazu","Spostrzezenie podejrzanych","Przybycie SWAT","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Restauracja Food Wall pod obserwacja."," - Detektyw Carl Sheary informuje, ze Alex Jimenez wchodzi do budynku."," - SWAT przybywa na miejsce. Zabezpieczenie terenu i rozmieszczenie snajperow."," - Decyzja szturmu. Grupa szturmowa zebrana.")
LoadingText=1572 Norman St., Restauracja Food Wall

[SP-ConvenienceStore]
PrimarySpawnPoint=Boczne wejscie
CampaignObjectiveEnemySpawn=("Alice Jenkins")
CampaignObjectiveHostageSpawn=("Willis Fillinger","Heidi Rosenstein","Kim Dong Yin")
MissionDescription=("Szturm","3721 Pitkin Avenue","18 listopada, godz. 07:15")
BriefingText=("Sytuacja przedstawia sie nastepujaco: okolo godziny 6:00 centrala odebrala wezwanie od klientki, ktora zatrzymala sie przy stacji, zeby zatankowac paliwo. Widzac, ze z budynku wychodzi uzbrojona kobieta, natychmiast odjechala i zawiadomila policje. Funkcjonariusze, ktorzy wkrotce potem pojawili sie na miejscu, zauwazyli kilku uzbrojonych podejrzanych i co najmniej trzech zakladnikow wewnatrz. Kiedy napastnicy zagrozili zastrzeleniem zakladnika, oddalili sie i zabezpieczyli teren.","|Jak na razie, znamy tozsamosc tylko jednego z podejrzanych, niejakiej Alice Jenkins. Wiemy, ze leczyla sie z uzaleznienia od oksykodonu, opiatu zblizonego do heroiny pod wzgledem sposobu dzialania i wlasciwosci uzalezniajacych. Oksykodon jest zaklasyfikowany jako lekarstwo klasy II, wiec kazdy, kto podrobi recepte, moze bawic sie w handlarza. Na ulicy dzialka kosztuje okolo 80 dolarow."," |Znajac Jenkins, podejrzewamy ze jest to po prostu nieudana proba kradziezy pieniedzy na narkotyki, co moze byc powiazane z niedawnym wysypem stoisk z narkotykami. Ona i jej wspoltowarzysze nie chcieli wziac zadnych zakladnikow i nie wiedza co z nimi teraz zrobic. To czyni sytuacje jeszcze bardziej niebezpieczna, gdyz nie mozemy przewidziec, co podejrzani zrobia z zakladnikami dalej, tym bardziej, ze zaprzestali rozmow z negocjatorem. Po zawilej mowie podejrzewamy, ze czesc z podejrzanych jest juz pod wplywem narkotyku. Moga byc uzbrojeni w pistolety, a na razie widzielismy przynajmniej trzech podejrzanych. Moze byc ich wiecej."," Podejrzewamy, ze jest troje zakladnikow: Kim Dong Yin, Heidi Rosenstein i Willis Fischer, sa to pracownicy stacji. Zakladnikami moga byc takze potencjalni klienci, ale jest to malo prawdopodobne. Badz szczegolnie ostrozny, kiedy tam sie znajdziesz. Bedziesz mial dodatkowe wsparcie snajperow przy dwoch wejsciach do kompleksu. Biorac pod uwage niedawna strzelanine, nie mozemy czekac ani chwili dluzej - czas na taktyczne rozwiazanie. Rozpoznaj sytuacje, wybierz odpowiedni ekwipunek i czym predzej ruszaj.")
LocationInfoText=("3721 Pitkin Avenue, stacja Qwik Fuel","|Drzwi frontowe prowadz a bezposrednio do sklepu, ale nie mozemy do nich podejsc ze wzgledow bezpieczenstwa. Za lada znajduje sie wejscie do biura, z ktorego mozna z kolei przejsc do czesci magazynowej. Poza wejsciem glownym do budynku prowadz a dwa wejscia zapasowe - boczne drzwi w czesci zaladunkowej i tylne drzwi po stronie 3.","|Sekcja Sierra Jeden oslania strone 1, poziom 1 i ma caly sklep w polu widzenia. Sierra Dwa oslania wasze podejscie do tylnych drzwi (strona 3, poziom 1).)
HostageName=("Heidi Rosenstein","Willis Fischer","Kim Dong Yin")
HostageVitals=("Plec: Kobieta|Rasa: Biala|Wzrost: 167 cm|Waga: Nieznana|Wlosy:Brazowe|Oczy: Brazowe|Data ur.: Nieznana|Wiek: Nieznany","Plec: Mezczyzna|Rasa: Biala|Wzrost: 178 cm|Waga: Nieznana|Wlosy: Brazowe|Oczy: Brazowe|Data ur.: Nieznana|Wiek: Nieznany","Plec: Mezczyzna|Rasa: Zolta|Wzrost: Nieznany|Waga: Nieznana|Wlosy: Brazowe|Oczy: Brazowe|Data ur.: Nieznana|Wiek: Nieznany")
HostageDescription=("Heidi Rosenstein pracuje na dziennej zmianie, od 06:00 do 14:00.","Szef zmiany wyszedl z domu o 5:30, powinien dotrzec na miejsce przed 6:00.","Pracownik nocnej zmiany na stacji Qwik Fuel. Prawdopodobnie wciaz przebywa w budynku, choc jego obecnosc nie zostala potwierdzona.")
SuspectName=("Alice Jenkins","Nieznany napastnik")
SuspectVitals=("Plec: Kobieta|Rasa: Biala|Wzrost: 168 cm|Waga: 65 kg|Wlosy: Brazowe|Oczy: Brazowe|Data ur.: 04/09/1977|Wiek: 31","Cechy: Nieznane")
SuspectDescription=("Alice Jenkins ma dosc bogata kartoteke. Obecnie jest na zwolnieniu warunkowym po aresztowaniu za posiadanie nielegalnych substancji. Brala udzial w licznych rozboj ach, zachowuje sie agresywnie i nieprzewidywalnie, czesto stawiala aktywny opor przy aresztowaniu.","Obecni na miejscu zdarzenia policjanci informuja, ze widzieli co najmniej dwoch innych uzbrojonych napastnikow. Kobieta zglaszajaca napad powiedziala, ze uzbrojeni sa w krotka bron palna.")
EntryOptionTitle=("Strona 2, Poziom 1 ")
EntryDescription=("Boczne wejscie")
TimeLinePlot=(0,33,66,100)
TimeLineTime=("06:15","06:30","06:45","07:15")
TimeLineShortDescription=("Zgloszenie","Przybycie SWAT","Negocjatorzy nawiazuja kontakt","Rozpoczecie szturmu")
TimeLineLongDescription=(" - Zgloszenie postronnego obserwatora, ktory zauwazyl uzbrojona osobe na stacji Qwik Fuel. Byc moze doszlo do wziecia zakladnikow. Informacja przekazana grupie szybkiego reagowania.","SWAT przybywa na miejsce. Snajperzy na pozycjach; potwierdzenie objecia calego terenu obserwacja.","Negocjatorzy z grupy kryzysowej potwierdzaja obecnosc 3 zakladnikow i co najmniej 3 uzbrojonych napastnikow. Grupa szturmowa zebrana."," - Slychac strzaly. Zapada decyzja o podjeciu szturmu.")
LoadingText=3721 Pitkin Avenue, stacja Qwik Fuel

[SP-Arcade]
PrimarySpawnPoint=Wejscie serwisowe
SecondarySpawnPoint=Drzwi ewakuacyjne
CampaignObjectiveEnemySpawn=("Javier Arias")
CampaignObjectiveHostageSpawn=("Oscar Bogard")
MissionDescription=("Podejrzani zaryglowani","1401 Gower Street","9 sierpnia - 16:50")
BriefingText=("Mamy zgloszenie o strzalach w FunTime Amusement Arcade. Javier Arias, lokalny diler, i jego ludzie padli ofiara klotni, ktora przerodzila sie w walke z uzyciem broni. Wiekszosc cywilow uciekla, ale niektorzy mogli pozostac. Moze byc tez wlasciciel, Oscar Bogard, zaginiony.","|Mozliwe, ze handlarze dokonuja przemocy w tej okolicy. Zachowaj ostroznosc; musimy zarowno ratowac cywilow, jak i zebrac dowody. Wybierz ekwipunek i wyrusz.")
LocationInfoText=("1401 Gower Street. FunTime Amusement Arcade","|FunTime dziala od ~20 lat. Przod na parterze to sala gier, tyl to zaplecze i mieszkanie wlasciciela. Moze tam byc ukryty wlasciciel.")
